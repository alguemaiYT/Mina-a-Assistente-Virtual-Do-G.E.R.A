# Environment Variables for Mina - Assistente Virtual Do G.E.R.A
# Copy this file to .env and fill in your values

# Groq API Key for STT (Speech-to-Text) transcription
# Get your API key from: https://console.groq.com/
GROQ_API_KEY=your_groq_api_key_here

# STT Library Path (optional - only if not using default location)
# Default: libs/stt/
# STT_LIBRARY_PATH=/custom/path/to/stt/library

# API Communication Library Path (optional)
# Default: libs/apicomm/
# APICOMM_LIBRARY_PATH=/custom/path/to/apicomm/library

# Logging Level (optional)
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
# LOG_LEVEL=INFO

# Audio Device Configuration (optional - overrides config.json)
# AUDIO_INPUT_DEVICE_INDEX=0
# AUDIO_OUTPUT_DEVICE_INDEX=0

# Wake Word Configuration (optional - overrides config.json)
# WAKE_WORD_ENABLED=true
# WAKE_WORD_SENSITIVITY=0.5

# Network Configuration (optional)
# WEBSOCKET_URL=wss://your-server.com/ws
# WEBSOCKET_ACCESS_TOKEN=your_access_token

# Development Settings
# DEBUG_MODE=false
# ENABLE_PROFILING=false
